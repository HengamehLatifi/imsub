{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Imsub: Run App",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/imsub",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env"
    },
    {
      "name": "Imsub: Run App With Example Env",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/cmd/imsub",
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env.example"
    },
    {
      "name": "Imsub: Debug Integration Tests",
      "type": "go",
      "request": "launch",
      "mode": "test",
      "program": "${workspaceFolder}/tests/integration",
      "cwd": "${workspaceFolder}",
      "buildFlags": "-tags=integration",
      "envFile": "${workspaceFolder}/.env"
    }
  ]
}
